<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access under the hardened runtime (required for notarization).
         Accessibility / CGEvent keystroke injection is gated by TCC, not by a
         hardened-runtime entitlement, so it needs nothing here. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
